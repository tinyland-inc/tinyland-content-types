{
  "name": "@tummycrypt/tinyland-content-types",
  "version": "0.2.4",
  "packageManager": "pnpm@10.13.1",
  "description": "Shared content type definitions for content management and ActivityPub federation",
  "type": "module",
  "license": "Zlib AND LicenseRef-Tinyland-Proprietary",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./visibility": {
      "types": "./dist/visibility/index.d.ts",
      "import": "./dist/visibility/index.js"
    },
    "./activitypub": {
      "types": "./dist/activitypub/index.d.ts",
      "import": "./dist/activitypub/index.js"
    },
    "./scheduling": {
      "types": "./dist/scheduling/index.d.ts",
      "import": "./dist/scheduling/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:package": "publint",
    "prepublishOnly": "pnpm build && pnpm check:package"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@types/node": "^24.6.0",
    "fast-check": "^4.3.0",
    "typescript": "^5.0.0",
    "publint": "^0.3.18",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://github.com/tinyland-inc/tinyland-content-types",
  "bugs": {
    "url": "https://github.com/tinyland-inc/tinyland-content-types/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyland-inc/tinyland-content-types.git"
  }
}
