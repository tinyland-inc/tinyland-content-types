{
  "name": "@tummycrypt/tinyland-content-types",
  "version": "0.1.0",
  "description": "Shared content type definitions for content management and ActivityPub federation",
  "type": "module",
  "license": "Zlib AND LicenseRef-Tinyland-Proprietary",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./visibility": {
      "types": "./dist/visibility/index.d.ts",
      "import": "./dist/visibility/index.js"
    },
    "./activitypub": {
      "types": "./dist/activitypub/index.d.ts",
      "import": "./dist/activitypub/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "fast-check": "^4.3.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/tinyland/projects/tinyland.dev.git",
    "directory": "packages/tinyland-content-types"
  }
}
